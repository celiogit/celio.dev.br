---
layout: layouts/base
---

<section class="page">
    <header class="header">
        {% if eyebrow %}
            <p class="eyebrow">{{ eyebrow }}</p>
        {% endif %}

        <h1 class="title">{{ title }}</h1>

        {% if description %}
            <p class="intro">{{ description }}</p>
        {% endif %}

        {% if meta %}
            <div class="infobox infobox--{{ tone or 'info' }} page__meta">
                <p class="content">{{ meta | safe }}</p>
            </div>
        {% endif %}
    </header>
    <div class="content">
        {{ content | safe }}
    </div>
</section>

