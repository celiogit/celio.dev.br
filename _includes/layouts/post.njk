---
layout: layouts/base
---

{% set visibleTags = tags | filterTagList %}

<section class="page page--post">
    <article class="post">
        <header class="header">
            <p class="eyebrow"><a href="./content/blog/index.njk">arquivo</a> / post</p>
            <h1 class="title">{{ title }}</h1>
            {% if description %}
                <p class="dek">{{ description }}</p>
            {% endif %}
            <div class="meta">
                <time class="datetime" datetime="{{ page.date | htmlDateString }}">
                    {% icon "custom:clock", width = "20px" %}
                    <span>{{ page.date | readableDate("dd 'de' LLL 'às' H:mm") }}</span>
                </time>
                {% if visibleTags and visibleTags.length %}
                    <ul class="tag-list" role="list" aria-label="Tags do post">
                        {% for tag in visibleTags %}
                            <li>{{ tag }}</li>
                        {% endfor %}
                    </ul>
                {% endif %}
            </div>
        </header>
        <div class="flow">
            {{ content | safe }}
        </div>
        {% if visibleTags and visibleTags.length %}
            <footer class="footer">
                <p class="label">Indexado em</p>
                <ul class="tag-list" role="list" aria-label="Tags do post no rodapé">
                    {% for tag in visibleTags %}
                        <li>{{ tag }}</li>
                    {% endfor %}
                </ul>
            </footer>
        {% endif %}
    </article>
</section>
