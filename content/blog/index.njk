---
layout: layouts/page
permalink: /blog/
eyebrow: arquivo
title: Blog
description: Todos os posts publicados até agora, em ordem cronológica.
eleventyComputed:
  meta: >
    {{ collections.posts.length }} post{% if collections.posts.length != 1 %}s{% endif %} publicado{% if collections.posts.length != 1 %}s{% endif %}.
eleventyNavigation:
    icon: edit
    key: Blog
    order: 3
---

{% if collections.posts.length > 0 %}
    <ol class="timeline" role="list">
        {% for post in collections.posts %}
            {% set visibleTags = post.data.tags | filterTagList %}
            <li>
                <article class="entry" tabindex="0">
                    <time class="datetime" datetime="{{ post.date | htmlDateString }}">
                        <span>{{ post.date | readableDate("dd 'de' LLL yyyy") }}</span>
                    </time>

                    <h2 class="title">
                        <a href="{{ post.url }}#main" tabindex="-1">{{ post.data.title }}</a>
                    </h2>

                    {% if post.data.description %}
                        <p class="excerpt">{{ post.data.description }}</p>
                    {% endif %}

                    {% if visibleTags and visibleTags.length %}
                        <ul class="tag-list" role="list" aria-label="Tags do post">
                            {% for tag in visibleTags %}
                                <li>{{ tag }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </article>
            </li>
        {% endfor %}
    </ol>
{% else %}
    <p>Nenhum post encontrado.</p>
{% endif %}
